{{#if error}}
<div class="ea-error">
  <p>Encounter not found. It may have been deleted.</p>
</div>
{{else}}
<div class="ea-builder">

  {{!-- Header Bar --}}
  <div class="ea-header">
    <input type="text" class="ea-encounter-name" value="{{encounter.name}}" placeholder="Encounter Name" />
    <input type="text" class="ea-tags-input" value="{{#each encounter.tags}}{{this}}{{#unless @last}}, {{/unless}}{{/each}}" placeholder="Tags (comma-separated)" />
    <div class="ea-header-buttons">
      <button class="ea-notes-btn" title="Notes"><i class="fas fa-sticky-note"></i></button>
      <button class="ea-export-btn" title="Export JSON"><i class="fas fa-download"></i></button>
      <button class="ea-save-btn" title="Save"><i class="fas fa-save"></i></button>
    </div>
  </div>

  {{!-- Three-panel layout --}}
  <div class="ea-panels">

    {{!-- LEFT: Party Panel --}}
    <div class="ea-panel ea-party-panel ea-party-drop-zone">
      <h3><i class="fas fa-users"></i> Party</h3>

      {{!-- Resource State Selector --}}
      <div class="ea-resource-selector">
        <label>Resource State</label>
        <select class="ea-resource-state">
          <option value="1.0"  {{#if rsFresh}}selected{{/if}}>Fresh (100%)</option>
          <option value="0.75" {{#if rsLightlyTaxed}}selected{{/if}}>Lightly Taxed (75%)</option>
          <option value="0.5"  {{#if rsHalfSpent}}selected{{/if}}>Half Spent (50%)</option>
          <option value="0.25" {{#if rsFumes}}selected{{/if}}>Running on Fumes (25%)</option>
          <option value="0.1"  {{#if rsCritical}}selected{{/if}}>Critical (10%)</option>
        </select>
      </div>

      <div class="ea-creature-list">
        {{#each party}}
        <div class="ea-creature-card" data-actor-id="{{this.actorId}}">
          <div class="ea-creature-header">
            <span class="ea-creature-name">{{this.name}}</span>
            <span class="ea-creature-stats">Lv{{this.level}} · AC {{this.ac}} · HP {{this.hp}}</span>
            <div class="ea-creature-buttons">
              <button class="ea-expand-toggle" title="Details"><i class="fas fa-chevron-down"></i></button>
              <button class="ea-remove-party" title="Remove"><i class="fas fa-times"></i></button>
            </div>
          </div>
          <div class="ea-detail ea-hidden">
            <div class="ea-detail-row"><strong>Classes:</strong> {{this.classDisplay}}</div>
            <div class="ea-detail-row"><strong>DPR:</strong> ~{{this.dprDisplay}}</div>
            <div class="ea-detail-row"><strong>Damage Types:</strong> {{this.dmgTypeDisplay}}</div>
            {{#if this.healingCapability}}
            <div class="ea-detail-row"><strong>Healing:</strong> ~{{this.healingCapability}}</div>
            {{/if}}
            <div class="ea-detail-row"><strong>Tags:</strong>
              {{#each this.displayTags}}<span class="ea-tag ea-tag-small">{{this}}</span> {{/each}}
            </div>
          </div>
        </div>
        {{/each}}
      </div>

      <div class="ea-drop-hint">Drag characters here from the Actors sidebar</div>

      {{#if hasAnalysis}}
      <div class="ea-panel-summary">
        <strong>Party:</strong> {{analysis.partySummary.count}} members ·
        {{analysis.partySummary.totalHP}} HP ·
        Avg AC {{analysis.partySummary.avgAC}} ·
        ~{{analysis.partySummary.totalDPR}} DPR
      </div>
      {{/if}}
    </div>

    {{!-- CENTER: Analysis Dashboard --}}
    <div class="ea-panel ea-analysis-panel">
      <h3><i class="fas fa-chart-bar"></i> Analysis</h3>

      {{#if hasAnalysis}}
      {{!-- Difficulty Gauge --}}
      <div class="ea-difficulty-gauge">
        <div class="ea-difficulty-label" style="color: {{difficultyColor}}">
          {{finalDifficulty}}
        </div>
        {{#if showXP}}
        <div class="ea-xp-display">
          <div>Monster XP: <strong>{{analysis.totalMonsterXP}}</strong></div>
          <div class="ea-xp-thresholds">
            Low {{analysis.xpBudget.low}} ·
            Mod {{analysis.xpBudget.moderate}} ·
            High {{analysis.xpBudget.high}} ·
            Deadly {{analysis.xpBudget.deadly}}
          </div>
        </div>
        {{/if}}
        {{#if difficultyChanged}}
        <div class="ea-difficulty-note">
          Raw: {{rawDifficulty}} → Adjusted: {{adjustedDifficulty}} → With resources: {{finalDifficulty}}
        </div>
        {{/if}}
      </div>

      {{!-- Action Economy --}}
      {{#if hasActionEconomy}}
      <div class="ea-action-economy">
        <div class="ea-section-title">Action Economy</div>
        <div class="ea-action-bars">
          <div>Party: <strong>{{analysis.partyActions}}</strong> actions/round</div>
          <div>Enemies: <strong>{{analysis.enemyActions}}</strong> actions/round</div>
        </div>
        <div class="ea-verdict">{{analysis.actionEconomyVerdict}}</div>
      </div>
      {{/if}}

      {{!-- Round Estimate --}}
      {{#if hasRounds}}
      <div class="ea-round-estimate">
        <div class="ea-section-title">Estimated Duration</div>
        <div class="ea-round-display">
          <strong>~{{analysis.estimatedRounds.estimatedDuration}} rounds</strong>
          (~{{analysis.estimatedRounds.realTimeMinutes}} min)
        </div>
        <div class="ea-round-detail">
          Party defeats enemies in ~{{analysis.estimatedRounds.toDefeatEnemies}} rounds ·
          Party survives ~{{analysis.estimatedRounds.toPartyWipe}} rounds
        </div>
        <div class="ea-attrition">
          Attrition winner: <strong>{{analysis.estimatedRounds.attritionWinner}}</strong>
        </div>
      </div>
      {{/if}}

      {{!-- Quick Stats --}}
      {{#if hasQuickStats}}
      <div class="ea-quick-stats">
        <div class="ea-section-title">Quick Stats</div>
        <div class="ea-stat-row">Party Avg AC: {{quickStats.partyAvgAC}} · Enemy Avg AC: {{quickStats.enemyAvgAC}}</div>
        <div class="ea-stat-row">Party DPR: ~{{quickStats.partyDPR}} · Enemy DPR: ~{{quickStats.enemyDPR}}</div>
      </div>
      {{/if}}

      {{!-- Warnings --}}
      {{#if hasWarnings}}
      <div class="ea-warnings">
        <div class="ea-section-title">Tactical Warnings</div>
        {{#each warnings}}
        <div class="ea-warning ea-warning-{{this.severity}}">
          <i class="fas {{this.iconClass}}"></i>
          <span class="ea-warning-text">{{this.message}}</span>
        </div>
        {{/each}}
      </div>
      {{/if}}
      {{/if}}
    </div>

    {{!-- RIGHT: Threats Panel --}}
    <div class="ea-panel ea-threats-panel ea-threats-drop-zone">
      <h3><i class="fas fa-skull-crossbones"></i> Threats</h3>

      <button class="ea-add-monster"><i class="fas fa-plus"></i> Add Monster</button>

      <div class="ea-creature-list">
        {{#each threats}}
        <div class="ea-creature-card" data-threat-idx="{{this.idx}}">
          <div class="ea-creature-header">
            <span class="ea-creature-name">{{this.name}}</span>
            <span class="ea-creature-stats">
              CR {{this.cr}} ·
              <input type="number" class="ea-threat-qty" value="{{this.quantity}}" min="1" max="50" title="Quantity" />×
            </span>
            <div class="ea-creature-buttons">
              <label class="ea-lair-label" title="Lair Actions">
                <input type="checkbox" class="ea-lair-toggle" {{#if this.hasLairActions}}checked{{/if}} /> Lair
              </label>
              <button class="ea-expand-toggle" title="Details"><i class="fas fa-chevron-down"></i></button>
              <button class="ea-remove-threat" title="Remove"><i class="fas fa-times"></i></button>
            </div>
          </div>
          <div class="ea-detail ea-hidden">
            <div class="ea-detail-row"><strong>AC:</strong> {{this.ac}} · <strong>HP:</strong> {{this.hp}}</div>
            <div class="ea-detail-row"><strong>Tags:</strong>
              {{#each this.displayTags}}<span class="ea-tag ea-tag-small">{{this}}</span> {{/each}}
            </div>
          </div>
        </div>
        {{/each}}
      </div>

      <div class="ea-drop-hint">Drag monsters here from the Actors sidebar</div>

      {{#if hasAnalysis}}
      <div class="ea-panel-summary">
        <strong>Threats:</strong> {{analysis.threatSummary.count}} creatures ·
        {{analysis.threatSummary.totalHP}} HP ·
        {{analysis.threatSummary.totalXP}} XP ·
        ~{{analysis.threatSummary.totalDPR}} DPR
      </div>
      {{/if}}
    </div>

  </div>
</div>
{{/if}}
